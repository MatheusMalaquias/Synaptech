    {
      "parameters": {
        "jsCode": "const parseBR = (v) => Number(String(v || 0).replace(/\\./g, '').replace(',', '.'));\n\nconst produtos = $(\"Get produtos\").all().map(item => item.json);\nconst notas = $input.all();\n\nreturn notas.map(item => {\n  const nota = item.json;\n  const valorBruto = parseBR(nota[\"Valor bruto\"]);\n\n  const candidatos = produtos.filter(p => {\n    const preco = parseBR(p[\"Preço\"]);\n    return preco > 0 && preco <= valorBruto;\n  });\n\n  const sorteado = candidatos.length\n    ? candidatos[Math.floor(Math.random() * candidatos.length)]\n    : { Produto: \"VALOR MUITO BAIXO\", Preço: 0.01 };\n\n  const precoUnit = parseBR(sorteado[\"Preço\"]);\n\n  return {\n    json: {\n      Produto: sorteado[\"Produto\"],\n      Preco_Unit: precoUnit,\n      Quantidade: precoUnit > 0 ? Number((valorBruto / precoUnit).toFixed(3)) : 0,\n      Valor_Total: valorBruto,\n      Forma_Pagamento: nota[\"Forma de pagamento\"] || \"Pix\",\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
