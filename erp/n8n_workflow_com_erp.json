      "parameters": {
        "jsCode": "// Log do resultado de cada venda registrada\nconst resultado = $input.first().json;\n\nif (resultado.sucesso) {\n  console.log(`✅ Venda #${resultado.numero} registrada: ${resultado.produto} | Qtd: ${resultado.quantidade} | Total: R$ ${resultado.total_final} | Forma: ${resultado.forma_pagamento}`);\n} else {\n  console.error(`❌ Falha ao registrar venda: ${JSON.stringify(resultado)}`);\n}\n\nreturn $input.all();"
