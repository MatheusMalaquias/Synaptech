# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=erp
POSTGRES_PASSWORD=troque_esta_senha_segura
POSTGRES_DB=erp
DATABASE_URL=postgresql+asyncpg://erp:troque_esta_senha_segura@postgres:5432/erp

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=troque_esta_senha_redis
REDIS_URL=redis://:troque_esta_senha_redis@redis:6379/0

# ── JWT ────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=gere_um_secret_de_64_chars_aqui_nunca_use_este_valor
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ── N8N ────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=troque_esta_senha_n8n
N8N_HOST=localhost
N8N_WEBHOOK_SECRET=secret_compartilhado_com_n8n

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=troque_esta_senha_minio
MINIO_BUCKET_NFCE=nfce-xml

# ── PIX (a definir conforme banco) ────────────────────────────
PIX_BASE_URL=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_CERT_PATH=

# ── NFC-e (Fase 5 — deixar vazio por ora) ─────────────────────
NFCE_AMBIENTE=2
NFCE_UF=35
NFCE_CERTIFICADO_PATH=
NFCE_CERTIFICADO_SENHA=

# ── Ambiente ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
